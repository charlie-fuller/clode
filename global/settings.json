{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/motorthings/.claude/statusline-command.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/motorthings/.claude/hooks/auto-convert-docs.py",
            "timeout": 120,
            "statusMessage": "Converting document..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/motorthings/.claude/hooks/precompact-context-preserver.py",
            "timeout": 120
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/motorthings/.claude/hooks/userpromptsubmit-context-injector.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
