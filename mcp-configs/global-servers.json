{
  "mcpServers": {
    "n8n-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {}
    },
    "elevenlabs": {
      "type": "stdio",
      "command": "uvx",
      "args": ["elevenlabs-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "YOUR_ELEVENLABS_API_KEY_HERE"
      }
    },
    "mem0": {
      "type": "stdio",
      "command": "npx",
      "args": ["@pinkpixel/mem0-mcp"],
      "env": {
        "MEM0_API_KEY": "YOUR_MEM0_API_KEY_HERE",
        "DEFAULT_USER_ID": "elizabeth"
      }
    },
    "cloner-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/Users/motorthings/Documents/GitHub/cloner-mcp",
        "run",
        "mcp_server.py"
      ],
      "env": {}
    },

  }
}
